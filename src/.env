# Transformer-based Embeddings configuration
EMBEDDINGS_MODEL_NAME=qwen3-embedding:latest

# Ollama LLM configuration
LLM_MODEL_NAME=gpt-oss:latest
LLM_TEMPERATURE=0.0        # Reliability: Lower is more factual, higher is more creative.
LLM_TOP_P=0.1              # Diversity: Limits word choices to the top 10% probability mass.
LLM_TOP_K=20               # Vocabulary: Restricts choices to the top 20 most likely words.
LLM_PRESENCE_PENALTY=0.1   # Novelty: Small nudge to introduce new topics/concepts.
LLM_FREQUENCY_PENALTY=0.1  # Flow: Small nudge to avoid repeating the same words.
LLM_MAX_TOKENS=32000

# LLM System Prompt
LLM_SYSTEM_PROMPT=You are a helpful assistant. Answer the question based on the context. Be detailed in your answers and show your reasoning. /no_think

# Indexing configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ChromaDB configuration
CHROMA_PERSIST_DIRECTORY=chroma_db
# Options: mlk_collection, newspark_collection, ypsilon_collection
CHROMA_COLLECTION_NAME=newspark_collection

# Retrieval configuration
N_RESULTS=15
SIMILARITY_THRESHOLD=0.4
MIN_CHUNK_SIZE=150
ENABLE_RERANKING=1

# Reference resolution (follow cross-references like "artikel 5", "bijlage A")
RESOLVE_REFERENCES=1

# Verbose output (displays details of chunks)
VERBOSE=1
