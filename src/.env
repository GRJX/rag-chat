# Transformer-based Embeddings configuration
EMBEDDINGS_MODEL_NAME=qwen3-embedding:latest

# Ollama LLM configuration
LLM_MODEL_NAME=gpt-oss:latest
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.5
LLM_MAX_TOKENS=32000

# LLM System Prompt
LLM_SYSTEM_PROMPT=You are a helpful assistant. Answer the question based on the context. Be detailed in your answers and show your reasoning. /no_think

# Indexing configuration
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ChromaDB configuration
CHROMA_PERSIST_DIRECTORY=chroma_db
CHROMA_COLLECTION_NAME=mlk_collection

# Retrieval configuration
N_RESULTS=15
SIMILARITY_THRESHOLD=0.002
MIN_CHUNK_SIZE=50
ENABLE_RERANKING=1

# Verbose output (displays details of chunks)
VERBOSE=0
